# =============================================================================
# CLAUDE-CODE-CLI-AGENTS-blueprint .gitignore
# Keeps runtime state, credentials, and machine-specific config out of git.
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENTIALS AND SECRETS (NEVER COMMIT)
# -----------------------------------------------------------------------------
.credentials.json
*.pem
*.key
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# RUNTIME STATE — escalations, handoffs, sessions (generated by the framework)
# -----------------------------------------------------------------------------
context/escalations/
context/handoffs/
context/projects/
context/hive/escalations/
context/hive/handoffs/
context/hive/sessions/
context/hive/active/
context/hive/completed/
context/hive/archive/
context/hive/events.ndjson
context/hive/events.ndjson.*
context/hive/events/
context/hive/events-*.ndjson
context/hive/hive-state.json
context/hive/events.ndjson.lock
context/hive/task-queue/
context/hive/reservations/
context/hive/observability/
context/hive/pilot/
context/hive/reports/
context/hive/nightly-queue.json
context/hive/nightly-queue.cache.json
context/hive/issue-planner-queue.json
context/hive/digests/
context/hive/logs/
context/hive/sprints/

# Session checkpoints / context manager request files
context/sessions/*_checkpoint.yaml
context/index_update_request.json

# Claude-internal sessions & history
sessions/
projects/
history.jsonl
*.log
*.tmp

# -----------------------------------------------------------------------------
# CACHE / TEMP (generated; machine-specific)
# -----------------------------------------------------------------------------
debug/
file-history/
session-env/
shell-snapshots/
statsig/
telemetry/
todos/
ide/
downloads/
__pycache__/
*.pyc
stats-cache.json

# Plugin data (per-install)
plugins/

# Plan / task files (per-session)
plans/
tasks/

# Settings (machine-specific; use settings.json.template as the shared starting point)
settings.json
settings.json.bak*

# Personal memory (local-only)
memory/

# Paste cache (clipboard data)
paste-cache/

# Config backups
backups/

# -----------------------------------------------------------------------------
# OS AND EDITOR FILES
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/settings.json
.idea/

# -----------------------------------------------------------------------------
# NESTED .claude/ (e.g. if someone puts agent-memory-local here)
# -----------------------------------------------------------------------------
.claude/

# MCP auth retry cache (runtime)
mcp-needs-auth-cache.json
