# =============================================================================
# CLAUDE CODE CLI AGENTS - .gitignore
# Security-focused exclusions for cross-VPS portability
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENTIALS AND SECRETS (NEVER COMMIT)
# -----------------------------------------------------------------------------
.credentials.json
*.pem
*.key
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# SENSITIVE SESSION DATA (Contains passwords, IPs, infrastructure details)
# -----------------------------------------------------------------------------
# These files contain production infrastructure details specific to deployments
# They should NOT be shared across machines for security reasons

# Session files with sensitive production data
context/sessions/TASK-001-PASSWORD-FIX-REPORT.md
context/sessions/NU-CCS-PROD-DEBUG-2025-12-04.yaml
context/sessions/vod01-cdr-backfill-2025-12-02.yaml
context/sessions/db-first-invoice-regen-2025-12-01.yaml

# Decisions containing infrastructure details
context/shared/decisions/DEC-007_server1_execution_target.md

# Escalations with server IPs
context/escalations/ESC-002_tf01_import_disk_space.md

# Handoffs with internal IPs
context/handoffs/HOFF-005_TEST-00_ORC-00_2025-12-14.md

# -----------------------------------------------------------------------------
# HIVE SESSION DATA (v3.8+ - runtime session state)
# -----------------------------------------------------------------------------
# Session folders contain project-specific runtime data
context/hive/sessions/
context/hive/active/
context/hive/completed/
context/hive/events.ndjson
context/hive/events/
context/index_update_request.json

# Per-host event streams and all event backup/temp variants
context/hive/events-*.ndjson
context/hive/events.ndjson.*

# Hive runtime state files (generated, machine-specific)
context/hive/hive-state.json
context/hive/events.ndjson.lock

# Hive runtime directories (generated, not version-controlled)
context/hive/task-queue/
context/hive/reservations/
context/hive/observability/
context/hive/pilot/
context/hive/reports/

# Escalations and handoffs contain project-specific context
context/escalations/
context/handoffs/
context/hive/escalations/
context/hive/handoffs/

# Claude internal session state (machine-specific)
sessions/

# Settings backups (machine-specific)
settings.json.bak*

# Paste cache (clipboard data)
paste-cache/

# -----------------------------------------------------------------------------
# PROJECT-SPECIFIC CONTEXT (User-specific, may contain sensitive paths)
# -----------------------------------------------------------------------------
# These directories contain project-specific context that varies by installation
context/projects/

# -----------------------------------------------------------------------------
# CLAUDE CODE INTERNAL PROJECT MEMORY (Auto-generated, machine-specific)
# -----------------------------------------------------------------------------
# Claude Code creates this directory to store per-project conversation memory
# Directory names are encoded paths like: -mnt-d-Dev-Projects-GitHub-myrepo/
# These are installation-specific and should never be committed
projects/

# Project-specific session checkpoints (may reference local paths)
context/sessions/*_checkpoint.yaml

# -----------------------------------------------------------------------------
# LARGE SESSION-SPECIFIC FILES
# -----------------------------------------------------------------------------
history.jsonl
*.log
*.tmp

# -----------------------------------------------------------------------------
# CACHE DIRECTORIES
# -----------------------------------------------------------------------------
debug/
file-history/
session-env/
shell-snapshots/
statsig/
telemetry/
todos/
ide/
downloads/
__pycache__/
*.pyc

# Config backups (contain sensitive settings)
backups/

# Stats cache
stats-cache.json

# Plugin data (installation-specific)
plugins/

# Plan files (session-specific)
plans/

# Task files (Claude Code internal task tracking, session-specific)
tasks/

# Settings (contains machine-specific hook paths, model preferences)
settings.json

# Personal memory (local-only, not portable across installations)
memory/

# -----------------------------------------------------------------------------
# OS AND EDITOR FILES
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/settings.json
.idea/

# -----------------------------------------------------------------------------
# Nightly-puffin runtime state (regenerated by local cron; machine-local)
# -----------------------------------------------------------------------------

# Nested .claude/ subdir — local settings + agent-memory-local + scheduled lock
.claude/

# MCP auth retry cache (runtime)
mcp-needs-auth-cache.json

# Nightly-puffin selector runtime output (regenerated 23:30 each night)
context/hive/nightly-queue.json
context/hive/nightly-queue.cache.json
context/hive/issue-planner-queue.json

# Digest output (machine-local; re-produced every morning at 06:45)
context/hive/digests/

# Cron/dispatcher logs (machine-local; rotated by the scripts themselves)
context/hive/logs/

# Sprint plan docs (machine-local; re-produced by evening-sprint-collate.sh)
context/hive/sprints/

# Separate workspace — versioned separately when ready
context/ci-cost-audit/
